#!/usr/bin/env python3
from abc import ABC, abstractmethod
import subprocess
import threading
import argparse
import shlex
import sys


VERSION = '2.0.0-beta.4'
stop_sudo = threading.Event()

parser = argparse.ArgumentParser(
    prog='pmm',
    description='Update your packages without the hassle of juggling fifteen different managers.',
)

parser.add_argument(
    '-n',
    '--dry-run',
    help='run the script without actually upgrading the packages',
    action='store_true',
)
parser.add_argument(
    '-y',
    '--yes',
    help='automatically update without asking for verification, assuming yes',
    action='store_true',
)
parser.add_argument(
    '--no-sudo',
    help='skips all package managers that require sudo',
    action='store_true',
)
parser.add_argument(
    '-v', '--version', help='print the program version and exit', action='store_true'
)
parser.add_argument(
    'managers', nargs='*', help='package managers to update (apt, flatpak, etc.)'
)

args = parser.parse_args()

if args.version:
    print(f'pmm, version {VERSION}')
    sys.exit(0)


def cyan(text: str) -> str:
    """Returns text in cyan color.

    Args:
        text: The text to return in cyan.
    """
    return f'\033[36m{text}\033[39m'


def header(text: str) -> str:
    """Returns the text provided converted into a heading.

    Args:
        text: The text to return as a heading.
    """
    return f'---------------< {text} >'.ljust(75, '-')


def keepsudo():
    """Background sudo keepalive thread."""
    while not stop_sudo.is_set():
        subprocess.run(
            ['sudo', '-v'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        stop_sudo.wait(150)


class PkgList:
    """Represents a formatted list of packages with version information."""

    def __init__(self):
        self.plist = ''
        self._has_updates = False

    def create(self, packages: list[dict], name: str) -> str | None:
        """Create a formatted list of packages with version information.

        Adds a heading and formats the text with ANSI escape codes for terminal output.

        Args:
            packages: List of package dictionaries with the following structure:
                [
                    {
                        'name': str,   # Package name
                        'oldv': str,   # Currently installed version
                        'newv': str,   # Available installation candidate
                    },
                    ...
                ]
                The list can contain any number of packages.

        Returns:
            str: The formatted package list with ANSI escape codes applied.
            This can be printed directly to the terminal or used for testing.
            None: The method will return None if there is any error.
        """
        if not packages:
            return None

        npad = max(len(p['name']) for p in packages) + 2
        opad = max(len(p['oldv']) for p in packages) + 2

        self.plist += f"\033[1;36m {f' {name} '.center(20, '=')}\033[22;39m\n\n"

        self.plist += (
            '\033[1m'
            + ' '
            + 'Package'.ljust(npad)
            + 'Old'.ljust(opad)
            + 'New'
            + '\033[22m'
            + '\n'
        )

        for item in packages:
            self.plist += (
                ' '
                + item['name'].ljust(npad)
                + item['oldv'].ljust(opad)
                + item['newv']
                + '\n'
            )

        self.plist = self.plist[:-1]  # remove last newline

        self.plist += '\033[0m'  # reset all styles

        self._has_updates = True

        return self.plist

    def updates(self, state: bool = None) -> bool:
        """Query or set the availability of updates for the manager.

        Args:
            state: If provided, sets the update availability state. If None (default),
                only queries the current state without modifying it.

        Returns:
            bool: The current state of update availability after any modification.
        """
        if state is not None:
            self._has_updates = state

        return self._has_updates

    def output(self, name: str = None) -> bool:
        """Print the formatted package list to the terminal.

        Returns:
            bool: True on success, False if the list is empty or if no updates are available.
        """
        if not self._has_updates or self.plist == '':
            # this code corrects undefined lists or no updates lists
            self.plist = ''
            self.plist += f"\033[1;36m {f' {name} '.center(20, '=')}\033[22m\n\n"
            self.plist += ' No updates available.\033[39m'
            print(self.plist)
            return False

        print(self.plist)
        return True


class BaseManager(ABC):
    """Common interface for all package manager wrappers."""

    def __init__(self, name: str, requires_sudo: bool = False):
        """Initialize a package manager.

        Args:
            name: The name of the package manager (e.g., 'apt', 'flatpak').
            requires_sudo: Whether this manager requires sudo privileges.
        """
        self.name = name
        self.requires_sudo = requires_sudo
        self.list = PkgList()

    @abstractmethod
    def check(self):
        """Check method that subclasses must implement.

        Returns:
            Will raise NotImplementedError as this class must implemented.
        """

        raise NotImplementedError('Subclasses must implement this method.')

    @abstractmethod
    def update(self):
        """Update method that subclasses must implement.

        Returns:
            Will raise NotImplementedError as this class must implemented.
        """

        raise NotImplementedError('Subclasses must implement this method.')


class AptManager(BaseManager):
    def __init__(self):
        super().__init__(name='apt', requires_sudo=True)

    def check(self):
        print(cyan(f"\n{header(f'Checking {self.name}')}\n"))

        try:
            subprocess.run(['sudo', 'apt-get', 'update'], check=True)
        except subprocess.CalledProcessError:
            print(cyan("Skipping apt: error while executing 'sudo apt-get update'."))
            return None

        # command source: https://sleeplessbeastie.eu/2025/02/06/how-to-list-upgradeable-packages-with-apt-and-apt-get/
        upgradable = subprocess.run(
            [
                'apt-get',
                '-o',
                '"APT::Get::Show-User-Simulation-Note=false"',
                '--quiet',
                '--quiet',
                '--simulate',
                'upgrade',
            ],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.split('\n')
        upgradable = [
            line for line in upgradable if line != '' if line.startswith('Inst ')
        ]  # clear empty values

        if not upgradable:
            return None

        packages = []
        for line in upgradable:
            splitline = shlex.split(line)
            packages.append(
                {
                    'name': splitline[1],
                    'oldv': splitline[2].strip('[]'),
                    'newv': splitline[3].lstrip('('),
                }
            )

        self.list.create(packages, 'Apt')

        return self.list

    def update(self):
        try:
            subprocess.run(['sudo', 'apt-get', 'upgrade', '--yes'], check=True)
        except subprocess.CalledProcessError:
            print(cyan(f'Skipping {self.name} update: error while updating.'))


MANAGERS = {'apt': AptManager}

instances: dict[str, BaseManager] = {}

# sudo keepalive
if not args.no_sudo:
    needs_sudo = False
    # check if we actually need sudo
    for man in args.managers:
        if man in MANAGERS and MANAGERS[man]().requires_sudo:
            needs_sudo = True
            break
    # ask for sudo
    if needs_sudo and subprocess.run(['sudo', '-v']).returncode == 0:
        # start sudo thread
        threading.Thread(target=keepsudo, daemon=True).start()
    elif needs_sudo:
        # failed sudo verification
        print(cyan('Exiting: failed sudo verification.'))
        sys.exit(1)

# check for updates
for man in args.managers:
    if man in instances:
        print(cyan(f'\nSkipping {man}: already checked.'))
        continue

    if man not in MANAGERS:
        print(cyan(f'\nUnknown manager {repr(man)}. Skipping to the next.'))
        continue

    instances[man] = MANAGERS[man]()

    if args.no_sudo and instances[man].requires_sudo is True:
        print(cyan(f'\nSkipping {man}: requires sudo.'))
        continue

    instances[man].check()

# make sure we recognize at least one manager
if instances == {}:
    print(
        cyan(
            f'''\
No managers have been recognized. The following managers are supported:
{', '.join(MANAGERS.keys())}
'''
        )
    )
    stop_sudo.set()
    sys.exit(1)

print(cyan(f"\n{header('Finished checking')}\n"))

# did the previous check return any new updates?
has_updates = False
for man, obj in instances.items():
    obj.list.output(man)
    if obj.list.updates():
        has_updates = True

# if we do have to update anything
if has_updates:
    if not args.yes:
        choice = (
            input(
                cyan(
                    '''
Would you like to update?
[Y]es / [n]o / [s]elect specific manager(s): '''
                )
            )
            .strip()
            .lower()
        )
    else:
        choice = 'y'

    print()
    match choice:
        case 'y' | '':
            for man, obj in instances.items():
                if obj.list.updates():
                    if not args.dry_run:
                        obj.update()
                    else:
                        print(cyan(f'Skipping {man} update: --dry-run passed'))
                else:
                    print(cyan(f'No updates available for {man}.'))
        case 'n':
            print(cyan('Exiting.'))
            stop_sudo.set()
            sys.exit(0)
        case 's':
            pass

stop_sudo.set()
print()
